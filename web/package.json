{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/build-data.mjs",
    "prebuild": "node scripts/build-data.mjs",
    "dev": "next dev",
    "build": "next build",
    "build:static": "node scripts/build-data.mjs && next build",
    "preview": "npx --yes serve out -l tcp://0.0.0.0:3000",
    "preview:lan": "npx --yes serve out -l tcp://0.0.0.0:3000",
    "open": "npm run build:static && npx --yes serve out -l tcp://0.0.0.0:3000",
    "deploy": "npm run build:static && npx --yes wrangler pages deploy out --project-name=bangdream-museum --branch=main",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@types/three": "^0.184.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.41.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
